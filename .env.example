# ============================================================
#  Chronicle AI — Environment Variables
#  Copy to .env.local for local dev. Never commit .env.local.
#
#  PRODUCTION: set these in your hosting provider (Vercel etc.)
#  except OPENAI_API_KEY — that goes in Supabase Edge Function
#  secrets only, never in the hosting provider.
# ============================================================

# ---- Supabase -----------------------------------------------
# Found at: Supabase Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ---- AI (OpenAI) ----------------------------------------------
# SERVER-SIDE ONLY. Set via Supabase Edge Function secrets.
# Run: supabase secrets set OPENAI_API_KEY=sk-...
# NEVER set this in Vercel/Netlify or any client-side env.
OPENAI_API_KEY=sk-...

# ---- App Config ----------------------------------------------
VITE_APP_NAME=Chronicle AI
VITE_APP_VERSION=0.1.0
VITE_APP_ENV=development

# ---- Feature Flags -------------------------------------------
# PRODUCTION: set all three to false
VITE_ENABLE_DEBUG_PANEL=true
VITE_ENABLE_DEV_TOOLS=true
VITE_ENABLE_MOCK_AI=false

# ---- Rate Limiting (Supabase Edge Function secrets) ----------
# Set these alongside OPENAI_API_KEY using supabase secrets set
AI_MAX_TOKENS=4096
AI_MAX_REQUESTS_PER_USER_PER_MINUTE=10
